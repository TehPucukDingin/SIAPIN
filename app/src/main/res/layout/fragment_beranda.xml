<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/tvTanggal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jum'at, 27 Februari 2026"
                    android:textSize="13sp"
                    android:textColor="#757575" />

                <TextView
                    android:id="@+id/tvSapaan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hi, siap untuk jalani hari ini?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Foto Profil -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgProfil"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@mipmap/ic_launcher"
                app:civ_border_width="2dp"
                app:civ_border_color="#FF6B35" />

        </RelativeLayout>

        <!-- Card Jadwal Hari Ini -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_jadwal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:elevation="2dp">

            <!-- Header Card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jadwal Hari Ini"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_centerVertical="true" />

                <TextView
                    android:id="@+id/tvLihatSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Semua"
                    android:textSize="13sp"
                    android:textColor="#FF6B35"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true" />

            </RelativeLayout>

            <!-- List Jadwal (container) -->
            <LinearLayout
                android:id="@+id/containerJadwal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Jika tidak ada jadwal -->
            <TextView
                android:id="@+id/tvNoJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tidak ada jadwal hari ini 🎉"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:layout_gravity="center"
                android:visibility="gone"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- Pintasan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pintasan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Chip Tugas -->
                    <LinearLayout
                        android:id="@+id/chipTugas"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pintasan_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_tugas"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tugas"
                            android:textSize="13sp"
                            android:textColor="#FF6B35"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Chip Jadwal -->
                    <LinearLayout
                        android:id="@+id/chipJadwal"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pintasan_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_jadwal_pin"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jadwal"
                            android:textSize="13sp"
                            android:textColor="#FF6B35"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Chip AI -->
                    <LinearLayout
                        android:id="@+id/chipAI"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pintasan_chip"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_ai_pin"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI"
                            android:textSize="13sp"
                            android:textColor="#FF6B35"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Card Progress Minggu Ini -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_progress_card"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:padding="20dp"
            android:gravity="center_vertical">

            <!-- Circle Progress -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="16dp">

                <com.mikhaellopez:circularprogressbar.CircularProgressBar
                    android:id="@+id/circularProgressBar"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cpb_progress="90"
                    app:cpb_progressMax="100"
                    app:cpb_progressBarColor="#FFFFFF"
                    app:cpb_backgroundProgressBarColor="#1565C0"
                    app:cpb_progressBarWidth="8dp"
                    app:cpb_backgroundProgressBarWidth="8dp"
                    app:cpb_roundBorder="true" />

                <TextView
                    android:id="@+id/tvProgressPersen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="90%"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </FrameLayout>

            <!-- Info Progress -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress Minggu Ini"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvTugasTersisa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 Tugas tersisa"
                    android:textSize="12sp"
                    android:textColor="#BBDEFB"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvTugasSelesai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9 Tugas telah dikumpulkan"
                    android:textSize="12sp"
                    android:textColor="#BBDEFB" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>